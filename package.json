{
  "name": "cronbuilder",
  "version": "0.1.0",
  "description": "Fluent cron expression builder, parser, validator, human-readable descriptions, and next-fire calculator. Zero dependencies.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "cron", "cron-expression", "cron-builder", "cron-parser", "cron-validator",
    "schedule", "scheduler", "next-cron", "cron-description", "crontab",
    "fluent", "builder", "typescript", "zero-dependency"
  ],
  "author": "trananhtung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trananhtung/cronbuilder"
  },
  "homepage": "https://github.com/trananhtung/cronbuilder#readme",
  "bugs": "https://github.com/trananhtung/cronbuilder/issues",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
